# Prompt Injection Defense Lab - .gitignore

# ===================================
# Environment & Secrets
# ===================================
# CRITICAL: Never commit API keys!
.env
.env.local
.env.development
.env.production
.env.test
*.env

# Backend environment
backend/.env
backend/.env.*

# Frontend environment
frontend/.env
frontend/.env.*

# ===================================
# Dependencies
# ===================================
# Node modules
node_modules/
*/node_modules/
backend/node_modules/
frontend/node_modules/

# Package lock files (choose one strategy)
# Option 1: Keep package-lock.json (recommended for consistency)
# Option 2: Ignore it (uncomment if you prefer)
# package-lock.json
# */package-lock.json

# Yarn
yarn.lock
.yarn/
.pnp.*
.yarn-integrity

# pnpm
pnpm-lock.yaml

# ===================================
# Build Outputs
# ===================================
# Backend build
backend/dist/
backend/build/
backend/*.js
backend/*.js.map
backend/src/**/*.js
backend/src/**/*.js.map

# Frontend build
frontend/dist/
frontend/build/

# Vite
.vite/
*/.vite/

# TypeScript
*.tsbuildinfo
.tsbuildinfo
tsconfig.tsbuildinfo

# ===================================
# Logs
# ===================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime logs
*.log.*
combined.log
error.log
access.log

# ===================================
# Testing
# ===================================
coverage/
*.lcov
.nyc_output/
test-results/
.jest/

# ===================================
# IDE & Editor
# ===================================
# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ===================================
# OS Files
# ===================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ===================================
# Temporary Files
# ===================================
tmp/
temp/
*.tmp
*.temp
.cache/
.parcel-cache/

# ===================================
# Runtime Data
# ===================================
pids/
*.pid
*.seed
*.pid.lock

# ===================================
# Optional npm cache directory
# ===================================
.npm

# ===================================
# Optional eslint cache
# ===================================
.eslintcache

# ===================================
# Optional stylelint cache
# ===================================
.stylelintcache

# ===================================
# Uploads & User Data (if applicable)
# ===================================
# If you add persistent storage later
uploads/
user-data/
*.db
*.sqlite
*.sqlite3

# ===================================
# Documentation Build
# ===================================
docs/_build/
.docz/

# ===================================
# Misc
# ===================================
# Debug files
*.orig
*.rej

# Lock files for other package managers
bun.lockb

# Sentry
.sentryclirc

# Serverless
.serverless/

# FuseBox
.fusebox/

# DynamoDB Local
.dynamodb/

# TernJS
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Temporary folders
tmp/
temp/

# ===================================
# Project Specific
# ===================================
# Add any project-specific patterns here

# Example documents that might contain real data
# Uncomment if you want to exclude sample documents
# examples/*.txt

# Backup files
*.backup
*.bak
*~

# Archive files if you create them
*.zip
*.tar.gz
*.rar

# Testing

# Agent skills
.agent/
.agents/
.skills-lock.json
.superpowers/
.skills/
skills-lock.json.superpowers/
skills-lock.json

#superpowers
docs/superpowers/
